<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns="ns://justiz.gv.at/Bilanzierung/v4.0/Bilanz" targetNamespace="ns://justiz.gv.at/Bilanzierung/v4.0/Bilanz" elementFormDefault="qualified" attributeFormDefault="unqualified">

	<!-- ///////////////////////////////////////////////////////// -->
	<!-- JAb 4.0 - XSD - Spezifikation in der Version 11           -->
	<!-- ///////////////////////////////////////////////////////// -->

	<!-- ///////////////////////////////////////////////////////// -->
	<!-- JAb 4.0 - HAUPTSTRUKTUR                                   -->
	<!-- ///////////////////////////////////////////////////////// -->

	<xs:element name="UEBERMITTLUNG">
		<xs:annotation>
			<xs:documentation>JAb 4.0 - Hauptstruktur</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="ALLGEMEINE_ANGABEN" type="ALLGEMEINE_ANGABEN" minOccurs="1" maxOccurs="1"/>

				<xs:choice minOccurs="1" maxOccurs="1">
					<xs:sequence>
						<xs:element name="BILANZ" type="BILANZ" minOccurs="1" maxOccurs="1"/>
						<xs:choice minOccurs="0" maxOccurs="1">
							<xs:element name="GUV_GKV" type="GUV_GKV" minOccurs="1" maxOccurs="1"/>
							<xs:element name="GUV_UKV" type="GUV_UKV" minOccurs="1" maxOccurs="1"/>
						</xs:choice>
						<xs:element name="ZUSATZANGABEN_MIKRO_AG" type="ZUSATZANGABEN_MIKRO_AG" minOccurs="0" maxOccurs="1"/>
					</xs:sequence>
					<xs:sequence>
						<xs:choice minOccurs="1" maxOccurs="1">
							<xs:element name="ANLAGE1_AUSZUG_AUS_DER_BILANZ" type="ANLAGE1" minOccurs="1" maxOccurs="1"/>
							<xs:element name="ANLAGE3_AUSZUG_AUS_DER_BILANZ" type="ANLAGE3" minOccurs="1" maxOccurs="1"/>
						</xs:choice>
						<xs:element name="ANLAGE2_OFFENZULEGENDER_ANHANG" type="ANLAGE2" minOccurs="0" maxOccurs="1"/>
					</xs:sequence>
				</xs:choice>

				<xs:element name="ANLAGENSPIEGEL" type="SPIEGEL_ANLAGEN" minOccurs="0" maxOccurs="1"/>
				<xs:element name="VERBINDLICHKEITENSPIEGEL" type="SPIEGEL_VERBINDLICHKEITEN" minOccurs="0" maxOccurs="1"/>
				<xs:element name="FORDERUNGENSPIEGEL" type="SPIEGEL_FORDERUNGEN" minOccurs="0" maxOccurs="1"/>
				<xs:element name="ENTWICKLUNG_DER_RUECKSTELLUNGEN" type="SPIEGEL_RUECKSTELLUNGEN" minOccurs="0" maxOccurs="1"/>
				<xs:element name="RUECKLAGENSPIEGEL" type="SPIEGEL_RUECKLAGEN" minOccurs="0" maxOccurs="1"/>

				<xs:element name="ANHANG" type="PDF_DATEN" minOccurs="0" maxOccurs="1"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	
	<!-- ///////////////////////////////////////////////////////// -->
	<!-- ALLGEMEINE ANGABEN - DATENTYPEN UND STANDARD - DATENTYPEN -->
	<!-- ///////////////////////////////////////////////////////// -->

	<xs:complexType name="ALLGEMEINE_ANGABEN">
		<xs:annotation>
			<xs:documentation>Datentyp für Allgemeine Angaben zur JAb-Übermittlung</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="BILANZ_VERSION" type="BILANZ_VERSION" minOccurs="1" maxOccurs="1"/>
			<xs:element name="PRUEFSUMME" type="PRUEFSUMME" minOccurs="0" maxOccurs="1"/>
			<xs:element name="SOFTWARE_HERSTELLER" type="SOFTWARE_HERSTELLER" minOccurs="1" maxOccurs="1"/>
			<xs:element name="BESTAETIGUNG_UEBEREINSTIMMUNG_ORIGINAL" type="BESTAETIGUNG_UEBEREINSTIMMUNG_ORIGINAL" minOccurs="1" maxOccurs="1"/>
			<xs:element name="JAHRESABSCHLUSS_KONZERNABSCHLUSS" type="JAHRESABSCHLUSS_KONZERNABSCHLUSS" minOccurs="1" maxOccurs="1"/>
			<xs:element name="UEBERSCHRIFT_DER_VISUALISIERUNG" type="UEBERSCHRIFT_DER_VISUALISIERUNG" minOccurs="0" maxOccurs="1"/>
			<xs:element name="GUV_AUSWEISART" type="GUV_AUSWEISART" minOccurs="0" maxOccurs="1"/>
			<xs:element name="FIRMENDATEN" type="FIRMENDATEN" minOccurs="1" maxOccurs="1"/>
			<xs:element name="GESCHAEFTSJAHR" type="GESCHAEFTSJAHR" minOccurs="1" maxOccurs="1"/>
			<xs:element name="GESCHAEFTSJAHR_VORANGEGANGEN" type="GESCHAEFTSJAHR_VORANGEGANGEN" minOccurs="0" maxOccurs="1"/>
			<xs:element name="BILANZ_WAEHRUNG" type="BILANZ_WAEHRUNG" minOccurs="1" maxOccurs="1"/>
			<xs:element name="AUFSTELLENDE_PERSONEN" type="PERSON_AUFSTELLENDE" minOccurs="1" maxOccurs="1"/>
		</xs:sequence>
	</xs:complexType>
	
	<xs:simpleType name="BILANZ_VERSION">
		<xs:annotation>
			<xs:documentation>Datentyp für die Jahresabschlussübermittlungsversion</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:minLength value="5"/>
			<xs:maxLength value="5"/>
			<xs:pattern value="04\.[0-9]{2}"/>
		</xs:restriction>
	</xs:simpleType>
	
	<xs:simpleType name="PRUEFSUMME">
		<xs:annotation>
			<xs:documentation>Datentyp für die Prüfsumme (SHA-256-Checksum)</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:minLength value="64"/>
			<xs:maxLength value="64"/>
			<xs:pattern value="[A-Za-z0-9]*"/>
		</xs:restriction>
	</xs:simpleType>
	
	<xs:complexType name="SOFTWARE_HERSTELLER">
		<xs:annotation>
			<xs:documentation>Datentyp für Bezeichnung des Software-Herstellers und der Software</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="HERSTELLER_BEZEICHNUNG" type="HERSTELLER_BEZEICHNUNG" minOccurs="1" maxOccurs="1"/>
			<xs:element name="SOFTWARE_BEZEICHNUNG" type="SOFTWARE_BEZEICHNUNG" minOccurs="1" maxOccurs="1"/>
			<xs:element name="SOFTWARE_VERSION" type="SOFTWARE_VERSION" minOccurs="1" maxOccurs="1"/>
		</xs:sequence>
	</xs:complexType>

	<xs:simpleType name="BESTAETIGUNG_UEBEREINSTIMMUNG_ORIGINAL">
		<xs:annotation>
			<xs:documentation>Datentyp für die Bestätigung der einreichenden Person</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:minLength value="1"/>
			<xs:maxLength value="1"/>
			<xs:pattern value="[JN]"/>
		</xs:restriction>
	</xs:simpleType>
	
	<xs:simpleType name="HERSTELLER_BEZEICHNUNG">
		<xs:annotation>
			<xs:documentation>Datentyp für die Bezeichnung des Software-Herstellers</xs:documentation>
		</xs:annotation>
		<xs:restriction base="ZEICHENFOLGE">
			<xs:minLength value="3"/>
			<xs:maxLength value="25"/>
		</xs:restriction>
	</xs:simpleType>

	<xs:simpleType name="SOFTWARE_BEZEICHNUNG">
		<xs:annotation>
			<xs:documentation>Datentyp für die Software-Bezeichnung</xs:documentation>
		</xs:annotation>
		<xs:restriction base="ZEICHENFOLGE">
			<xs:minLength value="3"/>
			<xs:maxLength value="25"/>
		</xs:restriction>
	</xs:simpleType>
	
	<xs:simpleType name="SOFTWARE_VERSION">
		<xs:annotation>
			<xs:documentation>Software-Version des Software-Herstellers</xs:documentation>
		</xs:annotation>
		<xs:restriction base="ZEICHENFOLGE">
			<xs:minLength value="3"/>
			<xs:maxLength value="25"/>
		</xs:restriction>
	</xs:simpleType>
	
	<xs:simpleType name="JAHRESABSCHLUSS_KONZERNABSCHLUSS">
		<xs:annotation>
			<xs:documentation>Datentyp für Art und Aufbau des Jahresabschlusses, oder Angabe des Konzernabschlusses</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="JAB"/>
			<xs:enumeration value="JAB-ANLAGE12"/>
			<xs:enumeration value="JAB-ANLAGE32"/>
			<xs:enumeration value="KAB"/>
		</xs:restriction>
	</xs:simpleType>
	
	<xs:simpleType name="UEBERSCHRIFT_DER_VISUALISIERUNG">
		<xs:annotation>
			<xs:documentation>Datentyp für die (optionale) Angabe der Überschriftsformulierung</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="A"/>
			<xs:enumeration value="B"/>
			<xs:enumeration value="V"/>
			<xs:enumeration value="L"/>
		</xs:restriction>
	</xs:simpleType>

	<xs:simpleType name="GUV_AUSWEISART">
		<xs:annotation>
			<xs:documentation>Datentyp für GUV-Ausweisart</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="G"/>
			<xs:enumeration value="R"/>
			<xs:enumeration value="A"/>
		</xs:restriction>
	</xs:simpleType>
	
	<xs:complexType name="FIRMENDATEN">
		<xs:annotation>
			<xs:documentation>Datentyp für Firmen-Details</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="FIRMENBUCHNUMMER" type="FIRMENBUCHNUMMER" minOccurs="1" maxOccurs="1"/>
			<xs:element name="FIRMENWORTLAUT" type="FIRMENWORTLAUT" minOccurs="1" maxOccurs="1"/>
		</xs:sequence>
	</xs:complexType>
	
	<xs:simpleType name="FIRMENBUCHNUMMER">
		<xs:annotation>
			<xs:documentation>Datentyp für Firmenbuchnummer</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="[0-9]{6}[a-z]"/>
		</xs:restriction>
	</xs:simpleType>
	
	<xs:complexType name="FIRMENWORTLAUT">
		<xs:annotation>
			<xs:documentation>Datentyp für Firmwortlaut</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="ZEILE" minOccurs="1" maxOccurs="11">
				<xs:complexType>
					<xs:simpleContent>
						<xs:extension base="ZEICHENFOLGE_OHNE_RAUTEUNTERSTRICH_38">
							<xs:attribute name="SORTIERUNG" use="required">
								<xs:simpleType>
									<xs:restriction base="xs:integer">
										<xs:minInclusive value="1"/>
										<xs:maxInclusive value="11"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:attribute>
						</xs:extension>
					</xs:simpleContent>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	
	<xs:complexType name="GESCHAEFTSJAHR">
		<xs:annotation>
			<xs:documentation>Datentyp für Informationen zum Geschäftsjahr</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="DATUM_DER_AUFSTELLUNG" type="xs:date" minOccurs="1" maxOccurs="1"/>
			<xs:element name="BEGINN" type="xs:date" minOccurs="1" maxOccurs="1"/>
			<xs:element name="ENDE" type="xs:date" minOccurs="1" maxOccurs="1"/>
			<xs:element name="RECHTSFORM" type="RECHTSFORM" minOccurs="1" maxOccurs="1"/>
			<xs:element name="GROESSENKLASSE" type="GROESSENKLASSE" minOccurs="1" maxOccurs="1"/>
			<xs:element name="EINGABEDARSTELLUNG" type="EINGABEDARSTELLUNG" minOccurs="1" maxOccurs="1"/>
			<xs:element name="ZIELDARSTELLUNG" type="ZIELDARSTELLUNG" minOccurs="0" maxOccurs="1"/>
		</xs:sequence>
	</xs:complexType>
	
	<xs:complexType name="GESCHAEFTSJAHR_VORANGEGANGEN">
		<xs:annotation>
			<xs:documentation>Datentyp für die Informationen zum vorangegangenen Geschäftsjahr</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="BEGINN" type="xs:date" minOccurs="1" maxOccurs="1"/>
			<xs:element name="ENDE" type="xs:date" minOccurs="1" maxOccurs="1"/>
			<xs:element name="RECHTSFORM" type="RECHTSFORM" minOccurs="1" maxOccurs="1"/>
		</xs:sequence>
	</xs:complexType>
	
	<xs:simpleType name="BILANZ_WAEHRUNG">
		<xs:annotation>
			<xs:documentation>Datentyp für die Bilanz-Währung</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="EUR"/>
		</xs:restriction>
	</xs:simpleType>
	
	<xs:complexType name="PERSON_AUFSTELLENDE">
		<xs:annotation>
			<xs:documentation>Datentyp für Liste der aufstellenden Personen</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="PERSON" type="PERSON" minOccurs="1" maxOccurs="unbounded"/>
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="PERSON">
		<xs:annotation>
			<xs:documentation>Datentyp für aufstellende Personen</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="PERSONENKENNUNG" type="PERSONENKENNUNG" minOccurs="0" maxOccurs="1"/>
			<xs:element name="GEBURTSDATUM" type="xs:date" minOccurs="1" maxOccurs="1"/>
			<xs:element name="TITEL" type="ZEICHENFOLGE_OHNE_RAUTEUNTERSTRICH_40" minOccurs="0" maxOccurs="1"/>
			<xs:element name="VORNAME" type="ZEICHENFOLGE_OHNE_RAUTEUNTERSTRICH_80" minOccurs="1" maxOccurs="1"/>
			<xs:element name="NACHNAME" type="ZEICHENFOLGE_OHNE_RAUTEUNTERSTRICH_80" minOccurs="1" maxOccurs="1"/>
			<xs:element name="TITEL_NACH" type="ZEICHENFOLGE_OHNE_RAUTEUNTERSTRICH_40" minOccurs="0" maxOccurs="1"/>
			<xs:element name="DATUM_UNTERSCHRIFT" type="xs:date" minOccurs="0" maxOccurs="1"/>
			<xs:element name="REGISTERBEZEICHNUNG" type="REGISTERBEZEICHNUNG" minOccurs="0" maxOccurs="1"/>
			<xs:element name="FIRMENBUCHNUMMER_REGISTERNUMMER" type="FIRMENBUCHNUMMER_REGISTERNUMMER" minOccurs="0" maxOccurs="1"/>
			<xs:element name="FIRMENWORTLAUT_BEZEICHNUNG" type="FIRMENWORTLAUT" minOccurs="0" maxOccurs="1"/>
		</xs:sequence>
	</xs:complexType>

	<xs:simpleType name="RECHTSFORM">
		<xs:annotation>
			<xs:documentation>Datentyp für Rechtsform</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="AG"/>
			<xs:enumeration value="EU"/>
			<xs:enumeration value="SCE"/>
			<xs:enumeration value="SE"/>
			<xs:enumeration value="EWI"/>
			<xs:enumeration value="GEN"/>
			<xs:enumeration value="GES"/>
			<xs:enumeration value="KG"/>
			<xs:enumeration value="OG"/>
			<xs:enumeration value="PST"/>
			<xs:enumeration value="SON"/>
			<xs:enumeration value="SPA"/>
			<xs:enumeration value="VER"/>
			<xs:enumeration value="FKG"/>
		</xs:restriction>
	</xs:simpleType>

	<xs:simpleType name="GROESSENKLASSE">
		<xs:annotation>
			<xs:documentation>Datentyp für Größenklasse</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="W"/>
			<xs:enumeration value="K"/>
			<xs:enumeration value="M"/>
			<xs:enumeration value="G"/>
		</xs:restriction>
	</xs:simpleType>
	
	<xs:complexType name="EINGABEDARSTELLUNG">
		<xs:annotation>
			<xs:documentation>Datentyp für die Eingabedarstellung der Bilanz</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="DARSTELLUNG_EINGEREICHT" type="DARSTELLUNG" minOccurs="1" maxOccurs="1"/>
			<xs:element name="DARSTELLUNG_VORHERGEHEND" type="DARSTELLUNG" minOccurs="0" maxOccurs="1"/>
		</xs:sequence>
	</xs:complexType>
	
	<xs:complexType name="ZIELDARSTELLUNG">
		<xs:annotation>
			<xs:documentation>Datentyp für die Zieldarstellung der Bilanz</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="DARSTELLUNG_EINGEREICHT" type="DARSTELLUNG" minOccurs="0" maxOccurs="1"/>
			<xs:element name="DARSTELLUNG_VORHERGEHEND" type="DARSTELLUNG" minOccurs="0" maxOccurs="1"/>
		</xs:sequence>
	</xs:complexType>
	
	<xs:complexType name="DARSTELLUNG">
		<xs:annotation>
			<xs:documentation>Datentyp für die Eingabe- und Zieldarstellung</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="EINHEIT" type="DARSTELLUNG_EINHEIT" minOccurs="1" maxOccurs="1"/>
			<xs:element name="NACHKOMMASTELLEN" type="DARSTELLUNG_NACHKOMMASTELLEN" minOccurs="1" maxOccurs="1"/>
		</xs:sequence>
	</xs:complexType>
	
	<xs:simpleType name="PERSONENKENNUNG">
		<xs:annotation>
			<xs:documentation>Datentyp für Personenkennung</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:minLength value="3"/>
			<xs:maxLength value="3"/>
			<xs:pattern value="[ ]*[A-Z]+"/>
		</xs:restriction>
	</xs:simpleType>
	
	<xs:simpleType name="REGISTERBEZEICHNUNG">
		<xs:annotation>
			<xs:documentation>Datentyp für Registerbezeichnungen</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="F"/>
			<xs:enumeration value="V"/>
			<xs:enumeration value="E"/>
			<xs:enumeration value="S"/>
			<xs:enumeration value="K"/>
		</xs:restriction>
	</xs:simpleType>
	
	<xs:simpleType name="FIRMENBUCHNUMMER_REGISTERNUMMER">
		<xs:annotation>
			<xs:documentation>Spezialdatentyp für alternative Angabe von Firmenbuchnummer 7-stellig oder sonstige Registernummer 20-stellig</xs:documentation>
		</xs:annotation>
		<xs:restriction base="ZEICHENFOLGE">
			<xs:minLength value="7"/>
			<xs:maxLength value="20"/>
		</xs:restriction>
	</xs:simpleType>

	<xs:simpleType name="PDF_DATEN">
		<xs:annotation>
			<xs:documentation>Datentyp für den PDF - Anhang (20 Megabyte)</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:base64Binary">
			<xs:maxLength value="20000000"/>
		</xs:restriction>
	</xs:simpleType>

	<!-- //////////////////////////////////////// -->
	<!-- DARSTELLUNG / BETRÄGE - DATENTYPEN       -->
	<!-- //////////////////////////////////////// -->
	
	<xs:simpleType name="DARSTELLUNG_EINHEIT">
		<xs:annotation>
			<xs:documentation>Datentyp für die Darstellungseinheiten</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="E"/>
			<xs:enumeration value="HE"/>
			<xs:enumeration value="TE"/>
			<xs:enumeration value="ZTE"/>
			<xs:enumeration value="HTE"/>
			<xs:enumeration value="ME"/>
		</xs:restriction>
	</xs:simpleType>
	
	<xs:simpleType name="DARSTELLUNG_NACHKOMMASTELLEN">
		<xs:annotation>
			<xs:documentation>Datentyp für die Nachkommastellendarstellung</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="G"/>
			<xs:enumeration value="N"/>
		</xs:restriction>
	</xs:simpleType>

	<xs:simpleType name="BETRAG">
		<xs:annotation>
			<xs:documentation>Datentyp für den Betrag (optionales Vorzeichen positiv/negativ, 12-stelliger Betrag mit optionalen 2 Nachkommastellen</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:minLength value="1"/>
			<xs:maxLength value="16"/>
			<xs:pattern value="(\+|-)?(([0-9]{1,12}(\.[0-9]{2})?)|[0-9]{1,12})" />
		</xs:restriction>
	</xs:simpleType>

	<xs:simpleType name="ANZAHL">
		<xs:annotation>
			<xs:documentation>Datentyp für die Verwendung bei Anzahlen (keine Vorzeichen, 12-stelliger Wert mit optionalen 2 Nachkommastellen</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:minLength value="1"/>
			<xs:maxLength value="15"/>
			<xs:pattern value="(([0-9]{1,12}(\.[0-9]{2})?)|[0-9]{1,12})" />
		</xs:restriction>
	</xs:simpleType>
	
	<!-- //////////////////////////////////////// -->
	<!-- STRING / ZEICHENFOLGEN - DATENTYPEN      -->
	<!-- //////////////////////////////////////// -->

	<xs:simpleType name="ZEICHENFOLGE">
		<xs:annotation>
			<xs:documentation>Datentyp für Zeichenfolge mit Firmenbuch-Sonderzeichen (Raute, Unterstrich)</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
