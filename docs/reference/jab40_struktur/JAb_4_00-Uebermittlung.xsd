			<xs:element name="UMBUCHUNGEN" type="BETRAG" minOccurs="1" maxOccurs="1"/>
			<xs:element name="ABGAENGE" type="BETRAG" minOccurs="1" maxOccurs="1"/>
			<xs:element name="ZUGAENGE_ABGAENGE_DURCH_UMGRUENDUNG" type="BETRAG" minOccurs="1" maxOccurs="1"/>
			<xs:element name="STAND_31_12" type="BETRAG" minOccurs="1" maxOccurs="1"/>
			
			<xs:element name="KUMULIERTE_WERTBERICHTIGUNGEN_01_01" type="BETRAG" minOccurs="1" maxOccurs="1"/>
			<xs:element name="LAUFENDE_ABSCHREIBUNGEN" type="BETRAG" minOccurs="1" maxOccurs="1"/>
			<xs:element name="LAUFENDE_ZUSCHREIBUNGEN" type="BETRAG" minOccurs="1" maxOccurs="1"/>
			<xs:element name="WERTBERICHTIGUNGEN_AUF_ZUGAENGE" type="BETRAG" minOccurs="1" maxOccurs="1"/>
			<xs:element name="WERTBERICHTIGUNGEN_AUF_UMBUCHUNGEN" type="BETRAG" minOccurs="1" maxOccurs="1"/>
			<xs:element name="WERTBERICHTIGUNGEN_AUF_ABGAENGE" type="BETRAG" minOccurs="1" maxOccurs="1"/>
			<xs:element name="WERTBERICHTIGUNGEN_ZUGAENGE_ABGAENGE_DURCH_UMGRUENDUNG" type="BETRAG" minOccurs="1" maxOccurs="1"/>
			<xs:element name="KUMULIERTE_WERTBERICHTIGUNGEN_31_12" type="BETRAG" minOccurs="1" maxOccurs="1"/>
			
			<xs:element name="BUCHWERT_01_01" type="BETRAG" minOccurs="1" maxOccurs="1"/>
			<xs:element name="BUCHWERT_31_12" type="BETRAG" minOccurs="1" maxOccurs="1"/>

			<xs:element name="BEZEICHNUNG" type="ZEICHENFOLGE_255" minOccurs="0" maxOccurs="1"/>
		</xs:sequence>
	</xs:complexType>

