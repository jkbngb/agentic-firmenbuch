	<!-- Datentyp für die Anlagenspiegel-Postenzeile -->
	<xs:complexType name="SPIEGEL_ANLAGEN_POSTENZEILE">
		<xs:annotation>
			<xs:documentation>
				Anschaffungs- und Herstellungskosten
				------------------------------------------------------------
				M | Stand 1.1.
				M | Zugänge
				M | davon aktivierte Zinsen für Fremdkapital
				M | Umbuchungen
				M | Abgänge
				M | Zugänge/Abgänge durch Umgründung (KFS/RL 25, Rz 37, 80)
				M | Stand 31.12.
				
				Kumulierte Wertberichtigungen (Abschreibungen)
				------------------------------------------------------------
				M | Kumulierte Wertberichtigungen 1.1.
				M | laufende Abschreibungen
				M | laufende Zuschreibungen
				M | Wertberichtigungen auf Zugänge
				M | Wertberichtigungen auf Umbuchungen
				M | Wertberichtigungen auf Abgänge
				M | Zugänge/Abgänge durch Umgründung (KFS/RL 25, Rz 81)
				M | Kumulierte Wertberichtigungen 31.12.
				
				Nettobuchwerte
				------------------------------------------------------------
				M | Buchwert 1.1.
				M | Buchwert 31.12.
			</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="STAND_01_01" type="BETRAG" minOccurs="1" maxOccurs="1"/>
			<xs:element name="ZUGAENGE" type="BETRAG" minOccurs="1" maxOccurs="1"/>
