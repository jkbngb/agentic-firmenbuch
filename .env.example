# ============================================================================
#  agentic-firmenbuch — environment template
#  Copy to `.env` and paste your secrets. `.env` is git-ignored; this file is tracked.
# ============================================================================

# ── 1) Firmenbuch HVD API (RUNTIME — the live data source) ──────────────────
# Auth is sent as an X-API-KEY header.
FIRMENBUCH_API_KEY=
JUSTIZONLINE_API_URL=https://justizonline.gv.at/jop/api/at.gv.justiz.fbw/ws

# ── 2) agentic-firmenbuch's OWN Azure (fill AFTER infra/setup.sh creates it) ─
# EU-only region policy: germanywestcentral -> westeurope -> northeurope
AZURE_LOCATION=germanywestcentral
AZURE_SUBSCRIPTION_ID=
COSMOS_ENDPOINT=
BLOB_ACCOUNT_URL=
KEY_VAULT_URI=
APPINSIGHTS_CONNECTION_STRING=
ACS_CONNECTION_STRING=


# ── 3) LLM inference (branch/ÖNACE classifier, issue #14 — OFFLINE/BATCH only) ─
# Used by the branch classifier to map the free-text Geschäftszweig to an ÖNACE code.
# Never in the live request path; an offline/batch job. Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 4) MCP auth surface ───────────────────────────────────────────────────────
# Anthropic Connectors Directory contract: EVERY unauthenticated /mcp request — including
# the first `initialize` — must return 401 + WWW-Authenticate. That is the DEFAULT (false).
# Set to true ONLY to restore anonymous handshake + tool-catalog preview (e.g. Glama registry
# health checks); doing so makes the reviewer's unauthenticated probe get 200 instead of 401.
MCP_ANONYMOUS_DISCOVERY=false

# ── misc ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
